{
  "name": "copy-skill",
  "version": "1.1.0",
  "description": "命令参考文档工具 - 左侧导航 + 右侧详情面板 + 一键复制",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "build:analyze": "vitepress build docs && npx vitepress inspect docs > inspect.html",
    "deploy": "npm run build && gh-pages -d docs/.vitepress/dist",
    "import": "node scripts/import-json.js",
    "import:example": "node scripts/import-json.js --example",
    "layout": "node scripts/update-layout.js",
    "layout:example": "node scripts/update-layout.js --example",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "vitepress": "^1.3.4",
    "vitest": "^4.1.5",
    "vue": "^3.4.21",
    "vue-eslint-parser": "^10.4.0"
  },
  "keywords": [
    "vitepress",
    "documentation",
    "commands",
    "reference"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "prismjs": "^1.30.0"
  }
}
